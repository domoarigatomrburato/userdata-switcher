{
  "name": "cursor-userdata-switcher",
  "displayName": "Cursor Userdata Switcher",
  "description": "Open Cursor with named isolated userdata roots.",
  "version": "0.1.0",
  "publisher": "cursor-userdata-switcher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domoarigatomrburato/cursor-subscription-quick-switcher.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorUserdata.openWithUserdata",
        "title": "Cursor Userdata: Open With Userdata"
      },
      {
        "command": "cursorUserdata.createUserdata",
        "title": "Cursor Userdata: Create Userdata"
      },
      {
        "command": "cursorUserdata.renameCurrentUserdata",
        "title": "Cursor Userdata: Rename Current Userdata"
      },
      {
        "command": "cursorUserdata.showCurrentUserdata",
        "title": "Cursor Userdata: Show Current Userdata"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "test": "tsx --test test/**/*.test.ts",
    "build": "npm run test && npm run compile",
    "package:vsix": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
