{
  "name": "userdata-switcher",
  "displayName": "Userdata Switcher",
  "description": "Open VS Code-family editors with named isolated userdata roots.",
  "version": "0.1.2",
  "type": "commonjs",
  "publisher": "domoarigatomrburato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domoarigatomrburato/userdata-switcher.git"
  },
  "engines": {
    "node": ">=22.13",
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "userdataSwitcher.openWithUserdata",
        "title": "Userdata Switcher: Open With Userdata"
      },
      {
        "command": "userdataSwitcher.createUserdata",
        "title": "Userdata Switcher: Create Userdata"
      },
      {
        "command": "userdataSwitcher.renameCurrentUserdata",
        "title": "Userdata Switcher: Rename Current Userdata"
      },
      {
        "command": "userdataSwitcher.showCurrentUserdata",
        "title": "Userdata Switcher: Show Current Userdata"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p .",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "npm run typecheck:test && tsx --test src/**/*.test.ts",
    "build": "npm run test && npm run compile",
    "package:vsix": "vsce package --no-dependencies",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}